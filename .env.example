# Shared runtime
APP_ENV=local
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Frontend public values only
# Vite exposes only VITE_* variables to browser code.
VITE_BACKEND_URL=http://localhost:8000
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_STORAGE_BUCKET=plant-photos

# Keep these only if a future Next.js frontend is added.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase: Auth + Postgres + Storage + pgvector
# Never expose DATABASE_URL or SUPABASE_SERVICE_ROLE_KEY to frontend code.
DATABASE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
JWT_AUDIENCE=authenticated
SUPABASE_STORAGE_BUCKET=plant-photos

# LLM / RAG
OPENAI_API_KEY=
CHAT_MODEL=gpt-4o-mini
VISION_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=farmhani-plant-doctor-rag

# Public agricultural data APIs
# API keys are used only by backend/data scripts, never by frontend.
NONGSARO_API_KEY=
NCPMS_API_KEY=
PSIS_API_KEY=
AIHUB_API_KEY=
# Optional alias used by the official AI Hub shell script.
AIHUB_APIKEY=
WEATHER_API_KEY=
# Public Data Portal service key for weather/agricultural observation APIs.
PUBLIC_DATA_PORTAL_API_KEY=

# Optional external object storage for source documents or large artifacts.
# If Supabase Storage is enough for MVP, these can remain empty.
OBJECT_STORAGE_BUCKET=farmhani-source-docs
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
